<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash screen configuration.
         Sets our logo as the splash icon and white background.
         Animation duration set to 0 to skip the native-to-Flutter transition. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/android12splash</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/white</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
    </style>
</resources>
